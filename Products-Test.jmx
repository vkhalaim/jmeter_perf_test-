            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223_Parse_Cart_for_next_sampler" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import groovy.json.JsonSlurper

def cartJson = vars.get(&apos;cartContent&apos;)
def cart = new JsonSlurper().parseText(cartJson)

def pIdBlock = new StringBuilder()
def pQtyBlock = new StringBuilder()

cart.keySet().each { key -&gt;
    pIdBlock.append(&apos;&apos;).append(key).append(&apos;,&apos;)
    pQtyBlock.append(&apos;1,&apos;)
}

vars.put(&apos;p_id_block&apos;, pIdBlock.toString()[0..-2])
vars.put(&apos;p_quantity_block&apos;, pQtyBlock.toString()[0..-2])</stringProp>
            </JSR223PostProcessor>
