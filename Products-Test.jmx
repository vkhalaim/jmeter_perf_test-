          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223_Choose_Random_Table" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">int max = Integer.parseInt(vars.get(&quot;tableProduct_matchNr&quot;))
int idx = 1 + new Random().nextInt(max)
vars.put(&quot;tableProductRandom&quot;, vars.get(&quot;tableProduct_&quot; + idx))</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223PostProcessor>
          <hashTree/>
