              <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223_Create_productPriceParts" enabled="true">
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="script">// clear products if exists
vars.remove(&quot;productPriceParts&quot;)

def boundary = vars.get(&quot;boundary&quot;)
def sb = new StringBuilder()
def cartContent = vars.get(&quot;cartContent&quot;)
def cartSize = cartContent.count(&quot;,&quot; ) + 1

// table is always present in the cart
def tableId = vars.get(&quot;tableProductId&quot;)
def tablePrice = vars.get(&quot;tableProductPrice&quot;)

if (tableId &amp;&amp; tablePrice) {
    sb.append(&quot;------WebKitFormBoundary&quot;).append(boundary).append(&quot;\r\n&quot;)
    sb.append(&quot;Content-Disposition: form-data; name=\&quot;product_price_&quot;)
      .append(tableId).append(&quot;__\&quot;\r\n\r\n&quot;)
    sb.append(tablePrice).append(&quot;\r\n&quot;)
}

// add chair when it&apos;s present
if (cartSize &gt; 1) {
	def chairId = vars.get(&quot;chairProductId&quot;)
	def chairPrice = vars.get(&quot;chairProductPrice&quot;)
	
	if (chairId &amp;&amp; chairPrice) {
	    sb.append(&quot;------WebKitFormBoundary&quot;).append(boundary).append(&quot;\r\n&quot;)
	    sb.append(&quot;Content-Disposition: form-data; name=\&quot;product_price_&quot;)
	      .append(chairId).append(&quot;__\&quot;\r\n\r\n&quot;)
	    sb.append(chairPrice).append(&quot;\r\n&quot;)
	}
}

vars.put(&quot;productPriceParts&quot;, sb.toString())</stringProp>
                <stringProp name="scriptLanguage">groovy</stringProp>
              </JSR223PreProcessor>
